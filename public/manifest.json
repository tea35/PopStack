{
  "manifest_version": 3,
  "name": "PopStack",
  "version": "1.0.0",
  "description": "技術記事の積読をPopに解消するツール",
  "permissions": [
    "storage",
    "activeTab",
    "bookmarks",
    "notifications",
    "alarms"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": { "default_icon": "icon.png" },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Command+Shift+S"
      }
    }
  }
}
