{
  "manifest_version": 3,
  "name": "PopStack",
  "version": "1.0.0",
  "description": "技術記事の積読をPopに解消するツール",
  "permissions": ["storage", "activeTab", "bookmarks", "notifications"],
  "action": {},
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Command+Shift+S"
      }
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
